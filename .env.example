# Admin credentials (required)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# NextAuth (required)
NEXTAUTH_SECRET=generate-a-random-secret-here   # e.g. openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000

# Database — SQLite (default, no extra config needed)
DB_BACKEND=sqlite
DATABASE_PATH=./data/wedding.db

# Database — MySQL (set DB_BACKEND=mysql and fill these in)
# DB_BACKEND=mysql
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=wedding
# DB_PASSWORD=secret
# DB_NAME=wedding

# Database — PostgreSQL (set DB_BACKEND=postgres and fill these in)
# DB_BACKEND=postgres
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=wedding
# DB_PASSWORD=secret
# DB_NAME=wedding

# Storage
UPLOAD_DIR=./uploads
STORAGE_BACKEND=disk

# Docker only: user the container runs as; owns files in data/ and uploads/
# (defaults to 1000:1000)
# UID=1000
# GID=1000

# Optional
# GALLERY_REFRESH_INTERVAL=30
# NEXT_PUBLIC_QR_CODE_SIZE=512
# NEXT_PUBLIC_QR_AVATAR_SIZE=0.35
